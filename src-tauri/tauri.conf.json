{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mdX",
  "version": "0.1.2",
  "identifier": "com.mdx.app",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:8080"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "mdX",
        "width": 1200,
        "height": 800,
        "center": true,
        "resizable": true,
        "transparent": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "visible": true,
        "backgroundColor": "#1a1a1a"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
